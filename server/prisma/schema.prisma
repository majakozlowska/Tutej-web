generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  COUNCILLOR
  ADMIN
}

enum ListingStatus {
  AVAILABLE
  RESERVED
  SOLD
}

model Neighborhood {
  id            Int            @id @default(autoincrement())
  name          String
  users         User[]
  posts         Post[]
  announcements Announcement[]
  events        Event[]
  listings      Listing[]
}

model User {
  id             Int            @id @default(autoincrement())
  firstName      String
  lastName       String
  email          String         @unique
  password       String
  photo          String?
  role           Role           @default(USER)
  neighborhoodId Int
  neighborhood   Neighborhood   @relation(fields: [neighborhoodId], references: [id])
  posts          Post[]
  comments       Comment[]
  announcements  Announcement[]
  listings       Listing[]
  attending      Event[]        @relation("EventAttendees")
  createdAt      DateTime       @default(now())
}

model Event {
  id             Int          @id @default(autoincrement())
  name           String
  description    String
  place          String
  date           DateTime
  neighborhoodId Int
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
  attendees      User[]       @relation("EventAttendees")
  createdAt      DateTime     @default(now())
}

model Post {
  id             Int          @id @default(autoincrement())
  title          String
  content        String
  media          String?
  authorId       Int
  author         User         @relation(fields: [authorId], references: [id])
  neighborhoodId Int
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
  comments       Comment[]
  createdAt      DateTime     @default(now())
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())
}

model Announcement {
  id             Int          @id @default(autoincrement())
  title          String
  content        String
  media          String?
  authorId       Int
  author         User         @relation(fields: [authorId], references: [id])
  neighborhoodId Int
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
  createdAt      DateTime     @default(now())
}

model Listing {
  id             Int           @id @default(autoincrement())
  title          String
  description    String
  price          Decimal?      @db.Decimal(10, 2)
  contact        String
  status         ListingStatus @default(AVAILABLE)
  authorId       Int
  author         User          @relation(fields: [authorId], references: [id])
  neighborhoodId Int
  neighborhood   Neighborhood  @relation(fields: [neighborhoodId], references: [id])
  createdAt      DateTime      @default(now())
}
